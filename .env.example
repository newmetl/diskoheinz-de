# Admin login password (plain text)
ADMIN_PASSWORD=change-me

# Secret used to sign/encrypt the admin session cookie.
# Must be at least 32 characters. Generate with: openssl rand -base64 48
ADMIN_SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Directory for SQLite DB and uploaded flyers.
# Defaults to ./data in dev; in Docker this is /app/data (mounted as volume).
# DATA_DIR=/app/data
